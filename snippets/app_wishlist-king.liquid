<script type="application/javascript" defer>
  window.wishlistKingReady = (WishlistKingSDK) => {
    const themeObserver = new WishlistKingSDK.Observer();

    // Header link desktop
    themeObserver.watch("any", "#AccessibleNav .site-nav__item:last-of-type", (target) => {
      target.insertBefore(
        new WishlistKingSDK.Marker("wishlist-link-li").create()
      );
    });

    // Header link mobile
    themeObserver.watch("any", ".site-nav--mobile .cart-link", (target) => {
      target.insertBefore(
        new WishlistKingSDK.Marker("wishlist-link").create()
      );
    });

    // Wishlist button on product page
    themeObserver.watch("product", "form[action='/cart/add']", (target) => {
      const productId = {{ product.id | json }};
      target.append(
        new WishlistKingSDK.Marker("wishlist-button-product", { id: productId }).create()
      );
    });

    // Wishlist button on collection page
    themeObserver.watch("any", "[data-product-id]", (target) => {
      target.append(
        new WishlistKingSDK.Marker("wishlist-button-collection", {
          id: target.element.getAttribute("data-product-id")
        }).create()
      );
    });

    WishlistKingSDK.toolkit.init({
      events: {
        ready() {
          // App is ready and WishlistKingSDK.toolkit.wk API can be used
        },
        addedToCart(product) {
          // This is a good place to trigger AJAX cart update
          window.scrollTo(0, 0);
          location.reload();
        },
        loginRequired() {
          window.location = [
            "/account/login?wk-redirect=",
            encodeURIComponent(JSON.stringify({
              path: window.location.pathname,
              intent: intent,
            }))
          ].join();
        }
      },
      shop: {
        domain: '{{ shop.domain }}',
        permanent_domain: '{{ shop.permanent_domain }}',
        currency: '{{ shop.currency }}',
        name: '{{ shop.name | replace: '&amp;', '&' }}',
      },
      session: {
        customer: '{{ customer.id }}',
        customer_email: '{{ customer.email }}',
      },
      globals: {
        settings: {
          app_wk_icon: '{{ settings.app_wk_icon }}',
          app_wk_products_per_row: {{ settings.app_wk_products_per_row }},
          money_format: '{{ shop.money_format }}',
          root_url: '{% unless request.locale.root_url == "/"  %}{{ request.locale.root_url }}{% endunless %}',
        },
        locale: {
          wishlist: "{{ 'app_wishlist-king.general.wishlist' | t }}",
          wishlist_empty_note: "{{ 'app_wishlist-king.general.wishlist_empty_note' | t }}",
          add_to_wishlist: "{{ 'app_wishlist-king.general.add_to_wishlist' | t }}",
          remove_from_wishlist: "{{ 'app_wishlist-king.general.remove_from_wishlist' | t }}",
          clear_wishlist: "{{ 'app_wishlist-king.general.clear_wishlist' | t }}",
          in_wishlist: "{{ 'app_wishlist-king.general.in_wishlist' | t }}",
          share_wishlist: "{{ 'app_wishlist-king.general.share_wishlist' | t }}",
          copy_share_link: "{{ 'app_wishlist-king.general.copy_share_link' | t }}",
          share_link_copied: "{{ 'app_wishlist-king.general.share_link_copied' | t }}",
          share_by_email_body: "{{ 'app_wishlist-king.general.share_by_email_body' | t }}",
          login_or_signup_note: "{{ 'app_wishlist-king.general.login_or_signup_note_html' | t: login_url: routes.account_login_url, register_url: routes.account_register_url }}",
          add_to_cart: "{{ 'app_wishlist-king.general.add_to_cart' | t }}",
          sold_out: "{{ 'app_wishlist-king.general.sold_out' | t }}",
          quantity: "{{ 'app_wishlist-king.general.quantity' | t }}",
          view_product: "{{ 'app_wishlist-king.general.view_product' | t }}",
          view_wishlist: "{{ 'app_wishlist-king.general.view_wishlist' | t }}",
          share_on_facebook: "{{ 'app_wishlist-king.general.share_on_facebook' | t }}",
          share_on_twitter: "{{ 'app_wishlist-king.general.share_on_twitter' | t }}",
          share_on_pinterest: "{{ 'app_wishlist-king.general.share_on_pinterest' | t }}",
          share_with_whatsapp: "{{ 'app_wishlist-king.general.share_with_whatsapp' | t }}",
          share_by_email: "{{ 'app_wishlist-king.general.share_by_email' | t }}",
          get_link: "{{ 'app_wishlist-king.general.get_link' | t }}",
          send_to_customer_service: "{{ 'app_wishlist-king.general.send_to_customer_service' | t }}",
        },
        customer: '{{ customer.id }}',
        customer_accounts_enabled: {{ shop.customer_accounts_enabled }},
      },
      wishlist: {
        filter: function(product) {
          return !product.hidden;
        },
        loginRequired: {{ settings.app_wk_login_required }},
        handle: "{{ pages["wishlist-new"].url }}",
        share: {
          handle: "{{ pages["shared-wishlist-new"].url }}",
          title: "{{ 'app_wishlist-king.general.share_list_title' | t }}",
          description: "{{ 'app_wishlist-king.general.share_list_description' | t: shopName: shop.name }}",
        }
      },
      tracking: {
        drip: false,
        facebook: false,
        google: false,
        klaviyo: false,
        simonData: false
      },
    });
  }
</script>

<script type="module">
  // Using type="module" breaks code highlighting in Shopify editor.
  // Keep the module code to a minimum.

  import WishlistKingSDK from "{{ "app_wishlist-king_sdk.js" | asset_url }}";
  import templates from "{{ "app_wishlist-king_templates.js" | asset_url }}";

  WishlistKingSDK.toolkit.setTemplates(templates);
  window.wishlistKingReady(WishlistKingSDK);
</script>

<link
  rel="preload"
  as="style"
  href="{{ 'app_wishlist-king.scss.css' | asset_url }}"
  onload="this.onload=null;this.rel='stylesheet'"
/>
